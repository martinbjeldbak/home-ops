---
customization:
  extraKernelArgs:
    - i915.enable_guc=3 # Intel iGPU (load GuC + HuC firmware for HW transcode)
    - intel_iommu=on # PCI Passthrough
    - iommu=pt # PCI Passthrough
    - mitigations=off # Disable CPU speculative-exec mitigations (trusted single-tenant homelab)
    - sysctl.kernel.kexec_load_disabled=1 # Harden kexec
  systemExtensions:
    officialExtensions:
      - siderolabs/i915 # Intel iGPU
      - siderolabs/intel-ucode # Intel iGPU
      - siderolabs/mei # Intel iGPU
      - siderolabs/realtek-firmware # Realtek NICs
